{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["eslint", "unicorn", "typescript", "oxc", "import"],
    "rules": {
        "import/extensions": ["error", "always", { "ignorePackages": true }],
        "typescript/ban-ts-comment": "error"
    },
    "overrides": [
        {
            "files": ["frontend/src/take/**"],
            "rules": {
                "no-restricted-imports": ["error", {
                    "patterns": [
                        {
                            "group": ["#fe/make/**"],
                            "message": "take/ must not import from make/. Both halves can use #fe/shared/** and root infrastructure (#fe/urls.ts)."
                        },
                        {
                            "group": ["#shared/**"],
                            "message": "take/ must not import from #shared/** (the FE↔specs contract zone — currently holds make-only fixture types). Use #fe/shared/** instead; if you need a shared contract type, expose it via shared/model/."
                        }
                    ]
                }]
            }
        },
        {
            "files": ["frontend/src/make/**"],
            "rules": {
                "no-restricted-imports": ["error", {
                    "patterns": [{
                        "group": ["#fe/take/**"],
                        "message": "make/ must not import from take/. Both halves can use #fe/shared/** and root infrastructure (#fe/urls.ts). #shared/** is allowed for make."
                    }]
                }]
            }
        }
    ]
}
