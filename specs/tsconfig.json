{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2023"],
        "module": "ESNext",
        "skipLibCheck": true,

        "paths": {
            "#steps/*": ["./src/steps/*"],
            "#pages/*": ["./src/pages/*"],
            "#coverage/*": ["./src/coverage/*"],
            "#specs/*": ["./src/*"],
            "#shared/*": ["../shared/*"]
        },
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "noEmit": true,
        "jsx": "react-jsx",

        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": [
        "playwright.config.ts",
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/coverage/report.js",
        "test/**/*.ts",
        "../shared/**/*.ts"
    ]
}
