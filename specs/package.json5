{
    "schema": "https://json.schemastore.org/package",
    "name": "quizmaster-specs",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "install:playwright": "pnpm playwright install chromium",

        "playwright:test": ". ../scripts/load-env.sh; bddgen && wait-on tcp:${E2E_BASE_PORT:-$BE_PORT} && playwright test",
        "playwright:watch": "chokidar 'features/**/*.feature' 'src/**/*.ts' -c bddgen",
        "playwright:ui": "concurrently 'pnpm playwright:watch' 'pnpm playwright:test --ui-host=0.0.0.0 --ui-port=3333'",

        "steps": "bddgen export --steps",
        "steps:unused": "bddgen export --unused-steps",

        "doc:gen": "node --require esbuild-register src/doc-gen/doc-gen.ts",

        "coverage:clean": "rm -rf coverage",
        "coverage:test:e2e": "pnpm coverage:clean && ENABLE_COVERAGE=1 c8 --experimental-monocart pnpm playwright:test",
        "coverage:report": "node src/coverage/report.js",
    },
    "dependencies": {
        "react": "19.2.4",
        "react-dom": "19.2.4",
    },
    "devDependencies": {
        // Types
        "@types/node": "25.5.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "typescript": "6.0.2",

        // Bundler
        "esbuild-register": "3.6.0",

        // BDD
        "@cucumber/cucumber": "12.7.0",
        "@playwright/test": "1.59.1",
        "playwright-bdd": "8.5.0",

        // Coverage
        "monocart-coverage-reports": "2.12.9",
        "c8": "11.0.0",

        // Living docs
        "@cucumber/gherkin" : "39.0.0",
        "@cucumber/messages" : "32.2.0",
        "react-markdown": "10.1.0",

        // Shell utils
        "chokidar-cli": "3.0.0",
        "concurrently": "9.2.1",
        "dotenv": "17.4.0",
        "wait-on": "9.0.4",
    }
}
