{
    "schema": "https://json.schemastore.org/package",
    "name": "quizmaster",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        // Worktree management
        "worktree:add": "./scripts/worktree-add.sh",
        "worktree:delete": "./scripts/worktree-delete.sh",

        // Install dependencies, psql client, Playwright browsers
        "env:init": "./scripts/init-env.sh",
        "install:fe": "cd frontend && pnpm install",
        "install:specs": "cd specs && pnpm install && pnpm install:playwright",
        "install:mcp": "cd mcp && pnpm install",
        "install:psql": "./scripts/install-psql.sh",

        "install:all": "pnpm env:init && pnpm install && pnpm install:fe && pnpm install:specs && pnpm install:mcp && pnpm install:psql",

        // Build scripts
        "build:fe:dev": "cd frontend && pnpm build:dev",
        "build:fe:prod": "cd frontend && pnpm build:prod",
        "build:be": "cd backend && ./gradlew build",
        "build:be:prod": "cd backend && ./gradlew bootJar",

        // Start Quizmaster in dev mode
        "start:be": "pnpm build:fe:dev && cd backend && ./gradlew bootRun",
        "start:fe": "cd frontend && pnpm dev",
        "mcp": "cd mcp && pnpm start",
        "start": "concurrently 'pnpm start:be' 'pnpm start:fe'",

        // Code quality
        "code:fe:tsc": "cd frontend && pnpm tsc -b && rm -f *.tsbuildinfo",
        "code:fe:lint": "oxlint --fix frontend/src/",
        "code:fe:format": "oxfmt frontend/src/",
        "code:fe": "pnpm code:fe:tsc && pnpm code:fe:lint && pnpm code:fe:format",

        "code:specs:tsc": "cd specs && pnpm tsc -b && rm -f *.tsbuildinfo",
        "code:specs:lint": "oxlint --fix specs/src/ specs/test/",
        "code:specs:format": "oxfmt specs/src/ specs/test/",
        "code:specs:gherkin": "cd specs && pnpm fmt features",
        "code:specs": "pnpm code:specs:tsc && pnpm code:specs:lint && pnpm code:specs:format && pnpm code:specs:gherkin",

        "code:mcp:tsc": "cd mcp && pnpm tsc -b && rm -f tsconfig.tsbuildinfo",
        "code:mcp:lint": "oxlint --fix mcp/src/ mcp/test/",
        "code:mcp:format": "oxfmt mcp/src/ mcp/test/",
        "code:mcp": "pnpm code:mcp:tsc && pnpm code:mcp:lint && pnpm code:mcp:format",

        "code": "pnpm code:fe && pnpm code:specs && pnpm code:mcp",

        // Unit tests
        "test:mcp": "cd mcp && pnpm test",
        "test:specs:fmt": "cd specs && pnpm test:fmt",
        "test:be:local": "cd backend && ./gradlew testLocal",
        "test:be:ai": "cd backend && ./gradlew testAi",
        "test:be": "cd backend && ./gradlew test",
        "coverage:be": "cd backend && ./gradlew jacocoTestReport",

        // Helper scripts, do not run directly
        "test:e2e:vite": ". scripts/load-env.sh && export E2E_BASE_PORT=$FE_PORT && cd specs && pnpm playwright:test",
        "test:e2e:be": ". scripts/load-env.sh && export E2E_BASE_PORT=$BE_PORT && cd specs && pnpm playwright:test",
        "test:e2e:playwright-ui": ". scripts/load-env.sh && export E2E_BASE_PORT=$FE_PORT && cd specs && pnpm playwright:ui",
        "coverage:e2e:run": ". scripts/load-env.sh && export E2E_BASE_PORT=$BE_PORT && cd specs && pnpm coverage:run && pnpm coverage:report",

        // E2E tests
        "test:e2e": "./scripts/test-e2e.sh",
        "test:e2e:dev": "./scripts/test-e2e.sh --dev",
        "test:e2e:ui": "./scripts/test-e2e.sh --ui",
        "coverage:e2e": "./scripts/test-e2e.sh --coverage",

        // BDD step catalog
        "steps": "cd specs && pnpm steps",
        "steps:unused": "cd specs && pnpm steps:unused",

        // CI scripts
        "build:ci:fe": "FEATURE_FLAG=true pnpm build:fe:prod",
        "build:ci:be": "FEATURE_FLAG=true pnpm build:be",
        "build:ci": "pnpm build:ci:fe && pnpm build:ci:be",

        "code:ci:tsc": "pnpm code:fe:tsc && pnpm code:specs:tsc && pnpm code:mcp:tsc",
        "code:ci:lint": "oxlint --deny-warnings frontend/src/ specs/src/ specs/test/ mcp/src/ mcp/test/",
        "code:ci:format": "oxfmt --check frontend/src/ specs/src/ specs/test/ mcp/src/ mcp/test/",
        "code:ci:gherkin": "cd specs && pnpm fmt --check features",
        "code:ci": "pnpm code:ci:tsc && pnpm code:ci:lint && pnpm code:ci:format && pnpm code:ci:gherkin",

        "test:e2e:ci": "FEATURE_FLAG=true ./scripts/test-e2e.sh",
    },
    "devDependencies": {
        "concurrently": "9.1.2",
        "oxfmt": "0.43.0",
        "oxlint": "1.58.0",
    }
}
