{
    "schema": "https://json.schemastore.org/package",
    "name": "quizmaster-fe",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --host",

        "build:dev": "vite build --sourcemap",
        "build:prod": "vite build",

        "code:tsc": "tsc -b && rm -f *.tsbuildinfo",
        "code:lint": "biome lint --fix",
        "code:format": "biome format --write",
        "code:ci": "tsc -b && biome ci",
        "code": "pnpm code:tsc && pnpm code:lint && pnpm code:format",
    },
    "dependencies": {
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-router-dom": "7.14.0"
    },
    "devDependencies": {
        // Types
        "@types/node": "25.5.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "typescript": "5.7.2",

        // Linting + formatting
        "@biomejs/biome": "1.9.4",

        // Bundler
        "vite": "6.0.2",
        "@vitejs/plugin-react": "4.3.4",
        "vite-tsconfig-paths": "5.1.3",
        "sass": "1.82.0",
    }
}
